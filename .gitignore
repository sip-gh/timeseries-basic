########################################
# secrets / local configs
########################################

.envrc          # direnv 設定ファイル（ローカル専用にする）
.direnv/        # direnv が作るキャッシュディレクトリ
.secrets/
src/.secrets/.env
config.*
.zs*


########################################
# data / tmp
########################################

# 生データなど、後から再取得できるもの
common/datum/
data/
tmp/

# strategies ディレクトリはコードを置くので ignore しない
# strategies


########################################
# dotenv (never commit)
########################################

.env
*.env
.env.*


########################################
# Python generated
########################################

__pycache__/
*.py[cod]
build/
dist/
*.egg-info/
.installed.cfg


########################################
# Jupyter / Jupytext
########################################

# Notebookのチェックポイントは常に無視
.ipynb_checkpoints/

# Notebook本体はGitに載せず、対応する .py を管理する
*.ipynb
notebooks_local/


########################################
# Virtual environments
########################################

.venv/
venv/
pyvenv.cfg


########################################
# IDE / editor
########################################
# launch.json などは除外
.vscode/launch.json
.vscode/extensions.json
.idea/


########################################
# macOS
########################################

.DS_Store
._*


########################################
# uv / Python version
########################################

# uv.lock は再現性のためコミット「する」
# .python-version もPythonバージョン固定に使うならコミット推奨


########################################
# lecture / 学習用メモ
########################################

lec*/
Prompt/
auto-trd-project/
